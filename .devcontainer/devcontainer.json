{
  "name": "ROS2-SMR",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "runArgs": [
    "--network=host",
    "--privileged"
  ],

  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "LIBGL_ALWAYS_SOFTWARE": "1"
  },

  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-iot.vscode-ros",
        "ranch-hand-robotics.rde-pack",
        "twxs.cmake",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "python.analysis.extraPaths": [
          "${workspaceFolder}/install/robot_interfaces/lib/python3.12/site-packages"
        ],
        "terminal.integrated.defaultProfile.linux": "bash",
        "ros.distro": "jazzy"
      }
    }
  },

  "postCreateCommand": "sudo rosdep init 2>/dev/null || true && rosdep update && rosdep install --from-paths src --ignore-src -r -y",

  "remoteUser": "ros"
}
